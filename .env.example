# Freelance-OS Environment Variables

# Paid Tier (Gemini Pro/Flash)
GOOGLE_API_KEY="your_google_api_key_here"

# Local Tier (Ollama)
# By default, Ollama runs on http://localhost:11434
OLLAMA_HOST="http://localhost:11434"
OLLAMA_DEFAULT_MODEL="llama3"

# Notion Integration
NOTION_API_KEY="your_notion_api_key_here"
NOTION_PARENT_PAGE_ID="your_notion_parent_page_id_here"
NOTION_LEADS_DB_ID="your_notion_leads_database_id_here"
NOTION_STRATEGY_DB_ID="your_notion_strategy_database_id_here"

# Canva Integration
CANVA_API_KEY="your_canva_api_key_here"
CANVA_PROPOSAL_TEMPLATE_ID="your_canva_proposal_template_id_here"
CANVA_CONTRACT_TEMPLATE_ID="your_canva_contract_template_id_here"
CANVA_ROADMAP_TEMPLATE_ID="your_canva_roadmap_template_id_here"
